! reactions for isobutanol model 
! Lactate production and traansport reaction(ldhA)
PYRU_M_RXN_LDH_D	:	nad_c + lac_D_c <-> h_c + pyr_c + nadh_c	! REVERSIBLE	! C21H26N7O14P2 + C3H5O3 <-> H + C3H3O3 + C21H27N7O14P2	! -1 + -1 <-> 1 + -1 + -2	! D-lactate dehydrogenase	! Pyruvate Metabolism	! b2133|b1380	! dld|ldhA
TR_IM_RXN_D_LACt2pp	:	lac_D_p + h_p <-> lac_D_c + h_c	! REVERSIBLE	! C3H5O3 + H <-> C3H5O3 + H	! -1 + 1 <-> -1 + 1	! D-lactate transport via proton symport (periplasm)	! Transport, Inner Membrane	! b3603|b2975	! lldP|glcA
TR_OM_POR_RXN_D_LACtex	:	lac_D_e <- lac_D_p	! REVERSIBLE	! C3H5O3 <- C3H5O3	! -1 <- -1	! D-lactate transport via diffusion (extracellular to periplasm)	! Transport, Outer Membrane Porin	! b0241|b0929|b1377|b2215	! phoE|ompF|ompN|ompC
! Ethanol production and transport reaction(adhE)
PYRU_M_RXN_ACALD	:	coa_c + nad_c + acald_c <-> nadh_c + accoa_c + h_c	! REVERSIBLE	! C21H32N7O16P3S + C21H26N7O14P2 + C2H4O <-> C21H27N7O14P2 + C23H34N7O17P3S + H	! -4 + -1 + 0 <-> -2 + -4 + 1	! acetaldehyde dehydrogenase (acetylating)	! Pyruvate Metabolism	! b0351|b1241	! mhpF|adhE
PYRU_M_RXN_ALCD2x	:	nad_c + etoh_c <-> acald_c + h_c + nadh_c	! REVERSIBLE	! C21H26N7O14P2 + C2H6O <-> C2H4O + H + C21H27N7O14P2	! -1 + 0 <-> 0 + 1 + -2	! alcohol dehydrogenase (ethanol)	! Pyruvate Metabolism	! b1478|b1241|b0356	! adhP|adhE|frmA
TR_IM_RXN_ETOHtrpp	:	etoh_p <-> etoh_c	! REVERSIBLE	! C2H6O <-> C2H6O	! 0 <-> 0	! ethanol reversible transport via diffusion (periplasm)	! Transport, Inner Membrane	! s0001	! s0001
TR_OM_POR_RXN_ETOHtex	:	etoh_e <- etoh_p	! REVERSIBLE	! C2H6O <- C2H6O	! 0 <- 0	! ethanol transport via diffusion (extracellular to periplasm)	! Transport, Outer Membrane Porin	! b0241|b0929|b1377|b2215	! phoE|ompF|ompN|ompC
! Acetyl phosphate production (ackA)
PYRU_M_RXN_ACKr	:	atp_c + ac_c <-> actp_c + adp_c	! REVERSIBLE	! C10H12N5O13P3 + C2H3O2 <-> C2H3O5P + C10H12N5O10P2	! -4 + -1 <-> -2 + -3	! acetate kinase	! Pyruvate Metabolism	! b3115|b2296|b1849	! tdcD|ackA|purT
PYRU_M_RXN_PTAr	:	pi_c + accoa_c <-> coa_c + actp_c	! REVERSIBLE	! HO4P + C23H34N7O17P3S <-> C21H32N7O16P3S + C2H3O5P	! -2 + -4 <-> -4 + -2	! phosphotransacetylase	! Pyruvate Metabolism	! b2297|b2458	! pta|eutD
! ISOBUTANOL PRODUCTION (kivD)
ENGISBUT1       	:	 oival_c -> isobutanal_c + co2_c       	!	Reduction   – Engineered gene                    	!	kivD 
ENGISBUT2       	:	 isobutanal_c + nadph_c -> isobutanol_c + nadp_c  	!	Reduction of a KEtone    – Engineered gene   	!	adh6
AMACIDBIOSYNTH51	:	dhval_c -> oival_c	!	Dihydroxy acid dehydratase - Branched Chain Amino Acid Biosynthesis	!	ilvD
AMACIDBIOSYNTH50	:	alac_S_c + nadph_c  -> nadp_c + dhval_c 	!	Acetohydroxy acid isomeroreductase   - Branched Chain Amino Acid Biosynthesis	!	ilvC
TR_IM_RXN_ISOBUTANOLtrpp	:	isobutanol_p <-> isobutanol_c	! REVERSIBLE	! C2H6O <-> C2H6O	! 0 <-> 0	! ethanol reversible transport via diffusion (periplasm)	! Transport, Inner Membrane	! unknownX
TR_OM_POR_RXN_ISOBUTANOLtex	:	isobutanol_e <- isobutanol_p	! REVERSIBLE	! C2H6O <- C2H6O	! 0 <- 0	! ethanol transport via diffusion (extracellular to periplasm)	! Transport, Outer Membrane Porin	! unknownY


## END REACTIONS

## MAXIMISE
TR_OM_POR_RXN_ISOBUTANOLtex
## END MAXIMISE

