VAL_LEU_ILE_M_RXN_VALTA	:	akg_c + val_L_c <- glu_L_c + 3mob_c	! REVERSIBLE	! C5H4O5 + C5H11NO2 <-> C5H8NO4 + C5H7O3	! -2 + 0 <-> -1 + -1	! valine transaminase	! Valine, Leucine, and Isoleucine Metabolism	! b3770	! ilvE
