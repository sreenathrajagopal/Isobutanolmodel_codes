TYR_TRP_PHE_M_RXN_PPND	:	nad_c + pphn_c -> 34hpp_c + co2_c + nadh_c	! LEFT-TO-RIGHT	! C21H26N7O14P2 + C10H8O6 -> C9H7O4 + CO2 + C21H27N7O14P2	! -1 + -2 -> -1 + 0 + -2	! prephenate dehydrogenase	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b2600	! tyrA
TYR_TRP_PHE_M_RXN_PPNDH	:	pphn_c + h_c -> co2_c + h2o_c + phpyr_c	! LEFT-TO-RIGHT	! C10H8O6 + H -> CO2 + H2O + C9H7O3	! -2 + 1 -> 0 + 0 + -1	! prephenate dehydratase	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b2599	! pheA
TYR_TRP_PHE_M_RXN_PRAIi	:	pran_c -> 2cpr5p_c	! LEFT-TO-RIGHT	! C12H13NO9P -> C12H13NO9P	! -3 -> -3	! phosphoribosylanthranilate isomerase (irreversible)	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b1262	! trpC
TYR_TRP_PHE_M_RXN_PSCVT	:	skm5p_c + pep_c <-> 3psme_c + pi_c	! REVERSIBLE	! C7H8O8P + C3H2O6P <-> C10H9O10P + HO4P	! -3 + -3 <-> -4 + -2	! 3-phosphoshikimate 1-carboxyvinyltransferase	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b0908	! aroA
TYR_TRP_PHE_M_RXN_SHK3Dr	:	3dhsk_c + h_c + nadph_c <-> nadp_c + skm_c	! REVERSIBLE	! C7H7O5 + H + C21H26N7O17P3 <-> C21H25N7O17P3 + C7H9O5	! -1 + 1 + -4 <-> -3 + -1	! shikimate dehydrogenase	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b1692|b3281	! ydiB|aroE
TYR_TRP_PHE_M_RXN_SHKK	:	atp_c + skm_c -> adp_c + h_c + skm5p_c	! LEFT-TO-RIGHT	! C10H12N5O13P3 + C7H9O5 -> C10H12N5O10P2 + H + C7H8O8P	! -4 + -1 -> -3 + 1 + -3	! shikimate kinase	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b3390|b0388	! aroK|aroL
TYR_TRP_PHE_M_RXN_TRPAS2	:	trp_L_c + h2o_c <-> indole_c + nh4_c + pyr_c	! REVERSIBLE	! C11H12N2O2 + H2O <-> C8H7N + H4N + C3H3O3	! 0 + 0 <-> 0 + 1 + -1	! Tryptophanase (L-tryptophan)	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b3708	! tnaA
TYR_TRP_PHE_M_RXN_TRPS3	:	3ig3p_c -> g3p_c + indole_c	! LEFT-TO-RIGHT	! C11H12NO6P -> C3H5O6P + C8H7N	! -2 -> -2 + 0	! tryptophan synthase (indoleglycerol phosphate)	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b1260&b1261	! trpA&trpB
TYR_TRP_PHE_M_RXN_TYRTA	:	akg_c + tyr_L_c <-> 34hpp_c + glu_L_c	! REVERSIBLE	! C5H4O5 + C9H11NO3 <-> C9H7O4 + C5H8NO4	! -2 + 0 <-> -1 + -1	! tyrosine transaminase	! Tyrosine, Tryptophan, and Phenylalanine Metabolism	! b4054|b0928	! tyrB|aspC
UA_P_RXN_CBMKr	:	atp_c + nh4_c + co2_c <-> adp_c + cbp_c + 2.0 * h_c	! REVERSIBLE	! C10H12N5O13P3 + H4N + CO2 <-> C10H12N5O10P2 + CH2NO5P + 2.0 * H	! -4 + 1 + 0 <-> -3 + -2 + 2.0 * 1	! Carbamate kinase	! Unassigned	! b0521|b0323|b2874	! ybcF|yahI|yqeA
UA_P_RXN_HCO3E	:	h2o_c + co2_c <-> hco3_c + h_c	! REVERSIBLE	! H2O + CO2 <-> CHO3 + H	! 0 + 0 <-> -1 + 1	! HCO3 equilibration reaction	! Unassigned	! b0126|b0339	! can|cynT
VAL_LEU_ILE_M_RXN_ACHBS	:	h_c + pyr_c + 2obut_c -> 2ahbut_c + co2_c	! LEFT-TO-RIGHT	! H + C3H3O3 + C4H5O3 -> C6H9O4 + CO2	! 1 + -1 + -1 -> -1 + 0	! 2-aceto-2-hydroxybutanoate synthase	! Valine, Leucine, and Isoleucine Metabolism	! b3670&b3671|b0077&b0078	! ilvN&ilvB|ilvI&ilvH
VAL_LEU_ILE_M_RXN_ACLS	:	2.0 * pyr_c + h_c -> alac_S_c + co2_c	! LEFT-TO-RIGHT	! 2.0 * C3H3O3 + H -> C5H7O4 + CO2	! 2.0 * -1 + 1 -> -1 + 0	! acetolactate synthase	! Valine, Leucine, and Isoleucine Metabolism	! b3670&b3671|b0077&b0078	! ilvN&ilvB|ilvI&ilvH
VAL_LEU_ILE_M_RXN_DHAD1	:	23dhmb_c -> 3mob_c + h2o_c	! LEFT-TO-RIGHT	! C5H9O4 -> C5H7O3 + H2O	! -1 -> -1 + 0	! dihydroxy-acid dehydratase (2,3-dihydroxy-3-methylbutanoate)	! Valine, Leucine, and Isoleucine Metabolism	! b3771	! ilvD
VAL_LEU_ILE_M_RXN_DHAD2	:	23dhmp_c -> 3mop_c + h2o_c	! LEFT-TO-RIGHT	! C6H11O4 -> C6H9O3 + H2O	! -1 -> -1 + 0	! Dihydroxy-acid dehydratase (2,3-dihydroxy-3-methylpentanoate)	! Valine, Leucine, and Isoleucine Metabolism	! b3771	! ilvD
VAL_LEU_ILE_M_RXN_ILETA	:	akg_c + ile_L_c <-> 3mop_c + glu_L_c	! REVERSIBLE	! C5H4O5 + C6H13NO2 <-> C6H9O3 + C5H8NO4	! -2 + 0 <-> -1 + -1	! isoleucine transaminase	! Valine, Leucine, and Isoleucine Metabolism	! b3770	! ilvE
VAL_LEU_ILE_M_RXN_IPMD	:	nad_c + 3c2hmp_c -> 3c4mop_c + h_c + nadh_c	! LEFT-TO-RIGHT	! C21H26N7O14P2 + C7H10O5 -> C7H8O5 + H + C21H27N7O14P2	! -1 + -2 -> -2 + 1 + -2	! 3-isopropylmalate dehydrogenase	! Valine, Leucine, and Isoleucine Metabolism	! b0073	! leuB
VAL_LEU_ILE_M_RXN_IPPMIa	:	3c2hmp_c <-> 2ippm_c + h2o_c	! REVERSIBLE	! C7H10O5 <-> C7H8O4 + H2O	! -2 <-> -2 + 0	! 3-isopropylmalate dehydratase	! Valine, Leucine, and Isoleucine Metabolism	! b0071&b0072	! leuD&leuC
VAL_LEU_ILE_M_RXN_IPPMIb	:	h2o_c + 2ippm_c <-> 3c3hmp_c	! REVERSIBLE	! H2O + C7H8O4 <-> C7H10O5	! 0 + -2 <-> -2	! 2-isopropylmalate hydratase	! Valine, Leucine, and Isoleucine Metabolism	! b0071&b0072	! leuD&leuC
VAL_LEU_ILE_M_RXN_IPPS	:	3mob_c + h2o_c + accoa_c -> h_c + coa_c + 3c3hmp_c	! LEFT-TO-RIGHT	! C5H7O3 + H2O + C23H34N7O17P3S -> H + C21H32N7O16P3S + C7H10O5	! -1 + 0 + -4 -> 1 + -4 + -2	! 2-isopropylmalate synthase	! Valine, Leucine, and Isoleucine Metabolism	! b0074	! leuA
VAL_LEU_ILE_M_RXN_KARA1	:	23dhmb_c + nadp_c <-> nadph_c + alac_S_c + h_c	! REVERSIBLE	! C5H9O4 + C21H25N7O17P3 <-> C21H26N7O17P3 + C5H7O4 + H	! -1 + -3 <-> -4 + -1 + 1	! ketol-acid reductoisomerase (2,3-dihydroxy-3-methylbutanoate)	! Valine, Leucine, and Isoleucine Metabolism	! b3774	! ilvC
VAL_LEU_ILE_M_RXN_KARA2	:	nadph_c + h_c + 2ahbut_c <-> nadp_c + 23dhmp_c	! REVERSIBLE	! C21H26N7O17P3 + H + C6H9O4 <-> C21H25N7O17P3 + C6H11O4	! -4 + 1 + -1 <-> -3 + -1	! ketol-acid reductoisomerase (2-Acetolactate)	! Valine, Leucine, and Isoleucine Metabolism	! b3774	! ilvC
VAL_LEU_ILE_M_RXN_LEUTAi	:	glu_L_c + 4mop_c -> akg_c + leu_L_c	! LEFT-TO-RIGHT	! C5H8NO4 + C6H9O3 -> C5H4O5 + C6H13NO2	! -1 + -1 -> -2 + 0	! leucine transaminase (irreversible)	! Valine, Leucine, and Isoleucine Metabolism	! b3770|b4054	! ilvE|tyrB
VAL_LEU_ILE_M_RXN_OMCDC	:	3c4mop_c + h_c -> 4mop_c + co2_c	! LEFT-TO-RIGHT	! C7H8O5 + H -> C6H9O3 + CO2	! -2 + 1 -> -1 + 0	! 2-Oxo-4-methyl-3-carboxypentanoate decarboxylation	! Valine, Leucine, and Isoleucine Metabolism	! s0001	! s0001
